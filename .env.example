# ── AutoDev Environment Configuration ────────────────────────────────────────
# Copy this file to .env and fill in your secrets.
# NEVER commit .env to version control.

ENV=development

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_MODEL=claude-opus-4-6
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# ── GitHub ────────────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/tokens
# Required scopes: repo, pull_requests
GITHUB_TOKEN=ghp_your-token-here
GITHUB_PR_BASE_BRANCH=main

# ── Database (override if not using docker-compose defaults) ──────────────────
DATABASE_URL=postgresql://autodev:autodev@postgres:5432/autodev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Analysis Thresholds (tune per team preferences) ───────────────────────────
MAX_CYCLOMATIC_COMPLEXITY=10
MAX_FUNCTION_LINES=50
MAX_NESTING_DEPTH=3
MAX_PARAMETERS=6
MAX_FILE_SIZE_CHANGE_PCT=0.30

# ── Storage ───────────────────────────────────────────────────────────────────
REPOS_BASE_PATH=/tmp/autodev_repos

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
